# Peripartner backend – copy to .env and fill in

PORT=4000
BASE_URL=http://localhost:4000

# Path to the master PDF (no watermark). Backend will add watermark per sale.
# Relative to backend folder
MASTER_PDF_PATH=./master/peripartner-guide.pdf

# Stripe: secret key (for SDK) and webhook secret (for verifying events)
# Obtain both from the Stripe dashboard (test or live mode).
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# (Optional, legacy) Gumroad webhook secret – only needed if you still use Gumroad
# GUMROAD_WEBHOOK_SECRET=your_webhook_secret

