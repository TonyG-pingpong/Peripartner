# Peripartner backend – copy to .env and fill in

PORT=4000
BASE_URL=http://localhost:4000

# Path to the master PDF (no watermark). Backend will add watermark per sale.
# Relative to backend folder
MASTER_PDF_PATH=./master/peripartner-guide.pdf

# Gumroad: set this in Gumroad dashboard → Product → Webhook. If Gumroad provides a secret, set it here.
# GUMROAD_WEBHOOK_SECRET=your_webhook_secret

# Optional: uncomment to verify webhook signature (when Gumroad supports it)
# GUMROAD_VERIFY_SIGNATURE=true
